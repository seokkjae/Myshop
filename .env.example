# 모닝브루 서버리스 함수용 환경변수 (실제 값은 .env 또는 Vercel 대시보드에 설정)
# .env 파일에는 절대 실제 service_role 키를 커밋하지 마세요 (.gitignore 로 제외됨)

# 모든 함수 공통
SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# 공개 예약 접수(/api/reserve)용 — anon(공개) 키
SUPABASE_ANON_KEY=your-anon-key

# 관리자(/api/admin) 전용 — service_role 키 (절대 브라우저/깃 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 관리자 로그인 비밀번호
ADMIN_PASSWORD=change-me
